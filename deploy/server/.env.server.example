# Copy these values into the server's root .env file and fill in the blanks.
# Keep the real .env untracked.

MEDUSA_ADMIN_EMAIL=admin@medusa.local
MEDUSA_PASSWORD=change-me
MEDUSA_ALLOW_DEFAULT_PASSWORD=false

# Dedicated-server runtime shape.
MEDUSA_PUBLIC_HOST=medusa.home.musial.io
MEDUSA_ALLOWED_HOSTS=medusa.home.musial.io
MEDUSA_BIND_IP=0.0.0.0
MEDUSA_BIND_IPV6=::1
MEDUSA_CPUSET=2-7
MEDUSA_IMPORT_WORKER_CONCURRENCY=2
MEDUSA_DOCUMENT_CACHE_SIZE_MB=51200
MEDUSA_VALKEY_MAXMEMORY=8gb
MEDUSA_WORKER_STALE_JOB_SECONDS=900
MEDUSA_RAW_TEXT_EXTRACTION_TIMEOUT_SECONDS=900

# Prometheus metrics exporter sidecar. Store the scrape bearer token in
# data/secrets/prometheus-token on the server and keep both token values private.
# auto preserves docker-compose.metrics.yml during deploy/release commands once
# the token file or another metrics credential is present.
MEDUSA_METRICS_OVERLAY=auto
MEDUSA_METRICS_BIND_IP=0.0.0.0
MEDUSA_METRICS_PORT=43737
MEDUSA_METRICS_REQUIRE_AUTH=true
MEDUSA_METRICS_BEARER_TOKEN_FILE=/app/data/secrets/prometheus-token
MEDUSA_METRICS_INTERNAL_TOKEN=
MEDUSA_METRICS_INTERNAL_SNAPSHOT_URL=http://backend:8000/api/internal/metrics/snapshot
MEDUSA_METRICS_HEAVY_TTL_SECONDS=900
MEDUSA_METRICS_DOCKER_SOCKET_PATH=

# Release status files remain under the ignored data directory.
MEDUSA_RELEASE_STATUS_PATH=/app/data/deploy/release-status.json
MEDUSA_RELEASE_REQUEST_PATH=/app/data/deploy/release-request.json
MEDUSA_RELEASE_HEALTHCHECK_IP=

# Google Cloud Storage and Google API credentials.
GCS_BUCKET=
GCS_PREFIX=medusa
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/app/data/secrets/service-account.json
MEDUSA_ENABLE_GOOGLE_VISION=true

# OpenAI and Gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MEDUSA_OPENAI_PRICING_TIER=standard
GEMINI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
MEDUSA_OPENAI_SEND_PDF=true
MEDUSA_OPENAI_PDF_FILE_MAX_MB=24
MEDUSA_OPENAI_COMBINE_DOCUMENT_INTELLIGENCE=false
MEDUSA_OPENAI_PROMPT_CACHE_RETENTION=24h
MEDUSA_OPENAI_NORMALIZE_PAGE_TEXT=true
MEDUSA_OPENAI_PAGE_NORMALIZATION_MODE=auto
MEDUSA_OPENAI_PAGE_NORMALIZATION_AUTO_MAX_PAGES=4
MEDUSA_OPENAI_TEXT_NORMALIZATION_PAGE_MAX_CHARS=14000
MEDUSA_OPENAI_REQUEST_TIMEOUT_SECONDS=180
MEDUSA_OPENAI_PAGE_NORMALIZATION_TIMEOUT_SECONDS=90
MEDUSA_OPENAI_EMBEDDING_TIMEOUT_SECONDS=60

# Related-paper discovery.
MEDUSA_RECOMMENDATIONS_ENABLE_OPENALEX=true
MEDUSA_RECOMMENDATIONS_ENABLE_SEMANTIC_SCHOLAR=true
MEDUSA_RECOMMENDATIONS_ENABLE_CROSSREF=true
MEDUSA_RECOMMENDATIONS_ENABLE_UNPAYWALL=true
MEDUSA_RECOMMENDATIONS_ENABLE_ARXIV=true
MEDUSA_RECOMMENDATIONS_MAX_PER_SOURCE=40
MEDUSA_RECOMMENDATIONS_REQUEST_TIMEOUT_SECONDS=16
MEDUSA_RECOMMENDATIONS_ARXIV_TITLE_LOOKUPS=8
MEDUSA_RECOMMENDATION_DOWNLOAD_TIMEOUT_SECONDS=60
MEDUSA_RECOMMENDATION_DOWNLOAD_MAX_MB=80
MEDUSA_OPENALEX_MAILTO=
MEDUSA_UNPAYWALL_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
MEDUSA_CITATION_TITLE_WEB_SEARCH=true
MEDUSA_CITATION_TITLE_WEB_SEARCH_TIMEOUT_SECONDS=8
